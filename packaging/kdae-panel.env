# HTTP 服务默认仅监听本机，请通过反向代理提供 HTTPS。
KDAE_PANEL_LISTEN=127.0.0.1:2023

# dae 与 systemd 集成。
KDAE_PANEL_DAE_BINARY=/usr/bin/dae
KDAE_PANEL_DAE_CONFIG=/etc/dae/config.dae
KDAE_PANEL_SERVICE_NAME=dae
KDAE_PANEL_SYSTEMCTL=/usr/bin/systemctl
KDAE_PANEL_JOURNALCTL=/usr/bin/journalctl

# 本地状态和配置备份。
KDAE_PANEL_DATABASE=/var/lib/kdae-panel/panel.db
KDAE_PANEL_BACKUP_DIR=/var/lib/kdae-panel/backups
KDAE_PANEL_SESSION_TTL=12h

# 通过 HTTPS 反向代理访问时改为 true。
KDAE_PANEL_SECURE_COOKIE=false

